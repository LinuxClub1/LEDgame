
#include <IRremote.h>
const int RECV_PIN = 2;
#define up 0X20DFA25D
#define down 0X20DF629D
#define left 0X20DFE21D
#define right 0X20DF12ED
IRrecv irrecv(RECV_PIN);
decode_results results;
int x=0;
int y=0;
int ysize=3;
int xsize=4;
struct led{
  int pin;
  int value;
};
led field [4] [3];
void UP()
{
if(y<ysize)
{
field[x][y].value=LOW;
y++;
}
}
void LEFT()
{
if(x<xsize)
{
field[x][y].value=LOW;
x++;
}
}
void DOWN()
{
if(y<ysize)
{
field[x][y].value=LOW;
y--;
}
}
void RIGHT()
{
if(x<xsize)
{
field[x][y].value=LOW;
x--;
}
}
